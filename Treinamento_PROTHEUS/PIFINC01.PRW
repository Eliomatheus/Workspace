#INCLUDE "TOTVS.CH"
/*/{Protheus.doc} PIFINC01
Tela de Correntista 
@type function
@author supor
@since 24/03/2026
/*/

// Criaçăo da Tela Com Funçőes de Validaçăo 
User Function PIFINC01()

	AxCadastro('SZ0', 'CORRENTISTA',"U_PIFINE01()", "U_PIFINE02()")

Return

// Validaçăo para verificar se existe conta na SZ1 
User Function PIFINE01() // Funçăo para excluir
	Local lRet := .T.

	SZ1->(DbSetOrder(1))
	If	SZ1->(DbSeek(xFilial("SZ1")+ SZ0->Z0_COD))
		Alert("Nao pode excluir correntista com conta no banco")
		lRet := .F.
	EndIf
Return lRet


// Validaçăo para verificar se existe conta na SZ1 
User Function PIFINE02() // Funçăo para Alterar
	Local lRet := .T.

	SZ1->(DbSetOrder(1))
	If	SZ1->(DbSeek(xFilial("SZ1")+ M->Z0_COD))
		Alert("Nao pode alterar correntista com conta no banco")
		lRet := .F.
	EndIf
Return lRet
